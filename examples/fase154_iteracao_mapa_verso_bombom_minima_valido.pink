pacote main;

carinho principal() -> bombom {
    nova m: mapa<verso,bombom> = mapa_verso_bombom_criar();
    mapa_verso_bombom_definir(m, "pontos", 42);

    nova muda total: bombom = 0;
    para cada chave em m {
        nova v: bombom = mapa_verso_bombom_obter(m, chave);
        total = total + v;
    }

    falar(total);
    mimo total;
}
