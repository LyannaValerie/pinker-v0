pacote main;

carinho principal() -> bombom {
    nova m: mapa<verso,bombom> = mapa_verso_bombom_criar();
    mapa_verso_bombom_definir(m, "pontos", 42);

    talvez mapa_verso_bombom_tem(m, "pontos") {
        nova v: bombom = mapa_verso_bombom_obter(m, "pontos");
        falar(v);
        mimo v;
    }

    mimo 0;
}
