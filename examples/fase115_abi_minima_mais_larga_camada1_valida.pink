pacote main;

// Fase 115: ABI mínima mais larga (camada 1 conservadora) no backend externo.
// Recorte: chamadas diretas com até 3 argumentos `bombom` usando registradores do SysV.
carinho soma3(a: bombom, b: bombom, c: bombom) -> bombom {
    nova muda total: bombom = a + b;
    total = total + c;
    mimo total;
}

carinho principal() -> bombom {
    nova muda base: bombom = 10;
    nova muda valor: bombom = soma3(base, 20, 3);
    valor = valor - 1;
    mimo valor;
}
