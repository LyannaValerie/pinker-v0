pacote main;

eterno BASE: u32 = 40;

carinho soma_u8(a: u8, b: u8) -> u8 {
    mimo a + b;
}

carinho soma_u16(a: u16, b: u16) -> u16 {
    mimo a + b;
}

carinho soma_u32(a: u32, b: u32) -> u32 {
