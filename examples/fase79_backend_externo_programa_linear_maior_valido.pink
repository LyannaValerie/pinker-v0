pacote main;

carinho etapa(a: bombom, b: bombom) -> bombom {
    nova muda t0: bombom = a + b;
    t0 = t0 * 2;
    t0 = t0 - 3;
    t0 = t0 + a;
    mimo t0;
}

carinho refina(x: bombom) -> bombom {
    nova muda t1: bombom = x * 3;
    t1 = t1 - 4;
    t1 = t1 + x;
    mimo t1;
}

carinho principal() -> bombom {
    nova muda v0: bombom = etapa(8, 5);
    nova muda v1: bombom = refina(v0);
    nova muda v2: bombom = etapa(v1, 7);
    v2 = v2 - 200;
    v2 = v2 + refina(10);
    mimo v2;
}
