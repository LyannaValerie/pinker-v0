pacote main;

// Fase 134: `virar` mínimo no backend externo (camada 2 conservadora).
// Recorte explícito desta fase: `u32 -> u64` (legado da 133) + `u64 -> u32` com origem em slot local/parâmetro.

carinho principal() -> bombom {
    nova origem_u32: u32 = 42;
    nova alargado: u64 = origem_u32 virar u64;

    nova origem_u64: u64 = alargado;
    nova reduzido: u32 = origem_u64 virar u32;

    talvez reduzido == 42 {
        mimo 134;
    } senao {
        mimo 0;
    }
}
