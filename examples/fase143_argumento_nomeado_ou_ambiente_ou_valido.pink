pacote main;

carinho principal() -> bombom {
    nova saida: verso = argumento_nomeado_ou_ambiente_ou("--saida", "PINKER_FASE143_SAIDA", "padrao.txt");
    nova usou_padrao: logica = igual_verso(saida, "padrao.txt");
    nova quiet: logica = tem_flag("--quiet");
    nova total: bombom = quantos_argumentos();
    falar(saida);
    falar(usou_padrao);
    falar(total);
    talvez quiet {
        mimo 1;
    } senao {
        mimo 0;
    }
}
