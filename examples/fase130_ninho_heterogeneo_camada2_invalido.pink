pacote main;

ninho RegistroHeterogeneoForaCamada2 {
    cabeca: bombom;
    ativo: logica;
}

carinho ler_logica_fora_camada2(base: seta<RegistroHeterogeneoForaCamada2>) -> bombom {
    nova ativo: logica = (*base).ativo;
    talvez ativo {
        mimo 1;
    } senao {
        mimo 0;
    }
}

carinho principal() -> bombom {
    mimo 0;
}
